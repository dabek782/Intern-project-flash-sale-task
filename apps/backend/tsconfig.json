{
  "ignoreDeprecations": "6.0",
  "compilerOptions": {
    "skipLibCheck": true,
    "outDir": "./dist",
    "strictNullChecks": true,
    "moduleResolution": "node16",
    "module": "Node16",
    "target": "ES2023",
    "strict": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  }
}
